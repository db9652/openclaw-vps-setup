# ╔══════════════════════════════════════════════════════════════╗
# ║  OpenClaw VPS Setup — Environment Variables                 ║
# ║  Copy this to .env and fill in your values                  ║
# ║  NEVER commit .env to git!                                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Required: Model Provider ──
# At minimum, you need one model provider API key
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Required: OpenAI (for memory search embeddings) ──
# Uses text-embedding-3-small (~$0.02 per million tokens)
OPENAI_API_KEY=sk-your_key_here

# ── Optional: Web Search (Brave Search) ──
# Free tier: 1 req/sec, 2000/month — https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=BSA_your_key_here

# ── Optional: Telegram Bot ──
# Get from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Gateway Settings ──
# Auto-generated if left blank; set for reproducible deployments
# OPENCLAW_GATEWAY_TOKEN=your_gateway_auth_token_here

# ── Timezone ──
# IANA timezone for your agent (affects heartbeat scheduling, logs)
TIMEZONE=Asia/Calcutta

# ── Optional: Agent Name ──
# Your agent's name (used in workspace templates)
AGENT_NAME=Snow

# ── Optional: Your Name ──
# How the agent should address you
USER_NAME=Vijay
